/-- The timed automata example from the thesis text,
formulated in nuXmv syntax
--/

@TIME_DOMAIN continuous

MODULE main
VAR
    s: {1, 2};
    c: clock;
INIT
    s = 1 & c = 0
TRANS -- from s_2, we can only transition to s_1
    s = 2 -> next(s) = 1
TRANS -- clock only changes discretely on reset
    next(c) = (s = 1 & next(s) = 2 ? 0 : c)
INVAR
    s = 1 -> c < 5
URGENT
    s = 2
DEFINE
    p := s = 1;
    q := s = 2;
LTLSPEC
    G(F[0,5](p))
LTLSPEC
    G(F[0,5](q))
